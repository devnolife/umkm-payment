{
  "name": "umkm",
  "version": "1.0.0",
  "private": true,
  "description": "Platform pemesanan makanan UMKM - Monorepo",
  "scripts": {
    "dev:web": "turbo run dev --filter=@umkm/web",
    "dev:mobile": "turbo run dev --filter=@umkm/mobile",
    "dev:api": "cd apps/api && go run ./cmd/server",
    "dev": "turbo run dev",
    "api:build": "cd apps/api && go build -o bin/api.exe ./cmd/server",
    "api:tidy": "cd apps/api && go mod tidy",
    "api:seed": "cd apps/api && go run ./cmd/seed",
    "api:dbcheck": "cd apps/api && go run ./cmd/dbcheck",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "turbo": "^2.8.10"
  }
}
